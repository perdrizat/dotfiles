# Fallback to vi if vim is not installed
vim() {
    if command -v vim >/dev/null 2>&1; then
        command vim "$@"
    else
        command vi "$@"
    fi
}
# set default editor
if command -v vim >/dev/null 2>&1; then
    export EDITOR='vim'
else
    export EDITOR='vi'
fi
export VISUAL="$EDITOR"

# Only cd to home if we are currently in a Windows drive mapping
if [[ "$PWD" == "/mnt/c/Users/mperd" ]]; then
    cd ~
fi

# Custom prompt for WSL
if [ -n "$WSL_DISTRO_NAME" ]; then
    # Default Maol prompt style, but with WSL name
    export PS1="\[\e]0;\u@$WSL_DISTRO_NAME: \w\a\]${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@$WSL_DISTRO_NAME\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ "
fi
